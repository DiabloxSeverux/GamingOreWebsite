{
  "name": "gamingore-website",
  "main": "worker.js",
  "compatibility_date": "2026-06-29",

  "assets": {
    "directory": "./public",
    "binding": "ASSETS",
    "run_worker_first": ["/download"]
  },

  "r2_buckets": [
    {
      "binding": "DOWNLOADS",
      "bucket_name": "gamingore-downloads"
    }
  ]
}
